{
  "expo": {
    "name": "Slippy",
    "slug": "slippy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "slippy",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image":           "./assets/splash.png",
      "resizeMode":      "contain",
      "backgroundColor": "#6366f1"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet":      false,
      "bundleIdentifier":    "app.slippy.mobile",
      "buildNumber":         "1",
      "infoPlist": {
        "NSCameraUsageDescription":       "ใช้กล้องเพื่อถ่ายรูปสลิปและใบเสร็จ",
        "NSPhotoLibraryUsageDescription": "เข้าถึงรูปภาพเพื่อเลือกสลิปและใบเสร็จ",
        "NSFaceIDUsageDescription":       "ใช้ Face ID เพื่อความปลอดภัยในการเข้าสู่ระบบ"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package":     "app.slippy.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": { "bundler": "metro", "output": "static", "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera",        { "cameraPermission": "ใช้กล้องเพื่อถ่ายรูปสลิปและใบเสร็จ" }],
      ["expo-image-picker",  { "photosPermission": "เข้าถึงรูปภาพเพื่อเลือกสลิปและใบเสร็จ" }],
      ["expo-notifications", { "icon":  "./assets/notification-icon.png", "color": "#6366f1" }],
      ["expo-local-authentication"]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "eas": { "projectId": "YOUR_EAS_PROJECT_ID" },
      "supabaseUrl":  "YOUR_SUPABASE_URL",
      "supabaseAnon": "YOUR_SUPABASE_ANON_KEY",
      "apiBase":      "https://api.slippy.app"
    }
  }
}
