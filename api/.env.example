# ══════════════════════════════════════════════════
#  DOC-HUB API — Environment Variables
#  Copy this file to .env and fill in values
# ══════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────
PORT=4000
NODE_ENV=development
INTERNAL_API_KEY=random-secret-for-internal-calls   # ต้องตรงกับ web

# ── Supabase (Service Role — full access) ─────────
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key          # NEVER expose to frontend

# ── Redis (BullMQ Queue) ───────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://your-upstash-url
REDIS_URL=redis://localhost:6379

# ── AI / OCR ──────────────────────────────────────
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key

# Google Document AI — https://console.cloud.google.com/
# สร้าง Processor ประเภท "Document OCR" แล้วใส่ full resource name
GOOGLE_DOC_AI_PROCESSOR_ID=projects/YOUR_PROJECT/locations/us/processors/YOUR_PROCESSOR_ID
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json   # path to service account JSON

# ── Encryption ─────────────────────────────────────
# ใช้สำหรับเข้ารหัส API keys ของลูกค้าใน DB
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64-char-hex-string

# ── Email (Cloudflare) ─────────────────────────────
# ตั้งค่าที่ Cloudflare Dashboard → Email Routing
EMAIL_DOMAIN=yourdomain.com
CLOUDFLARE_API_TOKEN=your-cloudflare-token

# ── Line Bot ──────────────────────────────────────
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# ── Storage ────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=documents
MAX_FILE_SIZE_MB=20

# ── FlowAccount (ไม่ใส่ที่นี่ — เก็บใน DB เข้ารหัส) ──
# ลูกค้าใส่ API Key ของตัวเองผ่าน Settings UI
# ระบบจะ encrypt และเก็บใน integrations table
